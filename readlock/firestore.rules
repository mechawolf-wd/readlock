rules_version = '2';

// Firestore security rules for Readlock.
//
// /courses/{courseId}        Signed-in reads. Admin (Lockie) writes.
// /courses/.../lessons/{}    No client reads. Admin writes. Cloud Function reads.
// /users/{userId}            Owner only. email + createdAt frozen after creation.
// /config/{document}         Signed-in reads. No client writes.
// /referral-codes/{codeId}   Creator reads own codes. Cloud Functions write.
//
// Client-writable user fields (UserService):
//   Preferences: typingSound, sounds, haptics, reveal, blur, coloredText,
//     bionic, rsvp, justifiedReading, readingFont, readingColumn,
//     rsvpWordsPerMinute, nightShiftLevel, nightShiftScheduleEnabled,
//     nightShiftScheduleFromMinutes, nightShiftScheduleToMinutes,
//     birdName, lastOpenedCourseId, hasCompletedOnboarding, language, fcmToken
//   Wallet: balance (via FieldValue.increment)
//   Progress: timeSpentReading (via FieldValue.increment),
//     courseProgress (map of per-course {courseId, currentLessonIndex})
//
// Server-managed fields (Cloud Functions, Admin SDK bypasses rules):
//   purchasedCourses: written by purchaseCourse / resurrectCourse callables

service cloud.firestore {
  match /databases/{database}/documents {

    // * Helpers

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'support@readlock.org';
    }

    // Fields that differ between existing doc and proposed write.
    // Used to enforce field-level immutability (email, createdAt).
    function changedFields() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function fieldUnchanged(name) {
      return !changedFields().hasAny([name]);
    }

    // * /courses/{courseId}

    match /courses/{courseId} {

      // Metadata only (titles, segments, isFree flags). Content is in /lessons.
      // Gated behind sign-in so anonymous scrapers can't pull the full catalog.
      // All authenticated users see the full catalog regardless of purchase state.
      allow read: if isSignedIn();

      // Only admin (Lockie) can publish. Counter bumps go through Cloud Functions.
      allow create, update, delete: if isAdmin();

      // * /courses/{courseId}/lessons/{lessonIndex}
      //
      // Lesson content. Docs keyed by flat index ("0", "1", "2", ...).
      // Client reads denied so content stays hidden from DevTools.
      // fetchLessonContent Cloud Function reads server-side (Admin SDK).
      // Lockie writes as admin via client SDK.

      match /lessons/{lessonIndex} {
        allow read: if false;
        allow write: if isAdmin();
      }
    }

    // * /users/{userId}

    match /users/{userId} {

      // Owner only. No cross-user reads. Admin/support access via Admin SDK.
      allow read: if isOwner(userId);

      // New profile: pin email + createdAt to auth values so a client can't
      // forge identity or backdate. Starter feather balance capped at 10.
      allow create: if isOwner(userId)
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.createdAt == request.time
        && request.resource.data.get('balance', 0) <= 10;

      // Owner updates only. email, createdAt, purchasedCourses frozen.
      // purchasedCourses is managed server-side by the purchaseCourse and
      // resurrectCourse Cloud Functions (Admin SDK bypasses rules).
      allow update: if isOwner(userId)
        && fieldUnchanged('email')
        && fieldUnchanged('createdAt')
        && fieldUnchanged('purchasedCourses');

      // Deletion goes through deleteAccount Cloud Function.
      // Blocked here so a stolen session can't nuke a profile directly.
      allow delete: if false;
    }

    // * /config/{document}
    //
    // Remote app config (URLs, pricing, feature flags).
    // Writes are admin-only (Firebase Console or Admin SDK).

    match /config/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // * /referral-codes/{codeId}
    //
    // Created and redeemed via Cloud Functions.
    // Users read only their own codes (populates "Invite friends" sheet).

    match /referral-codes/{codeId} {
      allow read: if isSignedIn()
        && resource.data.creatorUid == request.auth.uid;

      allow write: if false;
    }

    // * Default deny
    //
    // rules_version 2 already denies unmatched paths.
    // Explicit catch-all keeps the intent obvious.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';

// Firestore security rules for the Readlock app.
//
// Schema overview (gathered from the Flutter app + the Lockie publishing tool):
//
//   /courses/{courseId}
//     Catalog. Any signed-in client can read; anonymous reads are denied
//     so the full skillbook list isn't exposed to scrapers. Every write
//     (course creation / edit / delete and the `timesPurchased` counter
//     bump) is server-side only: Lockie publishes through the Admin SDK,
//     and the purchase callable cloud function bumps the counter. Both
//     bypass these rules, so direct client writes stay denied.
//
//   /users/{userId}
//     Strictly self-owned profile + preferences + feather wallet + FCM token.
//     Owner-only read/write. `email` and `createdAt` are frozen after
//     creation so a hijacked client can't rewrite identity. Account
//     deletion goes through the `deleteAccount` callable cloud function
//     (Admin SDK), which bypasses these rules.
//
// Client-side mutable fields (UserService):
//   Preferences: typingSound, sounds, haptics, reveal, blur, coloredText,
//     bionic, rsvp, justifiedReading, readingFont, readingColumn,
//     rsvpWordsPerMinute, nightShiftLevel, nightShiftScheduleEnabled,
//     nightShiftScheduleFromMinutes, nightShiftScheduleToMinutes,
//     birdName, lastOpenedCourseId, hasCompletedOnboarding, hasReaderPass,
//     language, fcmToken
//   Wallet: balance (via FieldValue.increment)
//   Library: purchasedCourses (array of {courseId, expires} records)
//   Progress: timeSpentReading (via FieldValue.increment),
//     courseProgress (map of per-course {courseId, currentLessonIndex})
//
// NOTE: `balance` and `purchasedCourses` are still mutated client-side
// today (PurchaseService). When those move to a callable cloud function,
// tighten the user-update rule to forbid direct writes to those fields.

service cloud.firestore {
  match /databases/{database}/documents {

    // * Helpers

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Set of fields whose value differs between the existing doc and the
    // proposed write. Used to enforce field-level immutability.
    function changedFields() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function fieldUnchanged(name) {
      return !changedFields().hasAny([name]);
    }

    // * /courses/{courseId}

    match /courses/{courseId} {

      // Catalog is gated behind sign-in so anonymous scrapers can't pull
      // the entire skillbook list. Every authenticated reader still gets
      // the full catalog regardless of purchase state.
      allow read: if isSignedIn();

      // Every write to /courses (create, edit, delete, and the
      // timesPurchased counter bump) goes through server-side code with
      // the Admin SDK: Lockie for authoring, the purchase callable
      // cloud function for the counter increment. Blocking every direct
      // client write here means a stolen session can neither publish
      // courses nor inflate the popularity counter.
      allow create, update, delete: if false;
    }

    // * /users/{userId}

    match /users/{userId} {

      // Owner reads their own profile. No cross-user reads; any support /
      // debugging access goes through the Admin SDK server-side, which
      // bypasses these rules.
      allow read: if isOwner(userId);

      // Profile creation: owner only, with the doc's identity fields
      // pinned to the authenticated request so a client can't forge a
      // foreign email or backdate the createdAt timestamp. The starter
      // feather balance is capped at the value the app seeds new users
      // with (NEW_USER_STARTING_BALANCE = 10) so a fresh sign-up can't
      // mint extra feathers on the first write.
      allow create: if isOwner(userId)
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.createdAt == request.time
        && request.resource.data.get('hasReaderPass', false) == false
        && request.resource.data.get('balance', 0) <= 10;

      // Profile updates: owner only. Identity fields (email, createdAt)
      // are frozen so the owner can't rewrite their identity after the
      // fact. The balance field can only decrease or stay the same on a
      // direct client write (purchases deduct feathers); top-ups that
      // increase balance should eventually move to a callable, but the
      // increment guard is relaxed here because the mock purchase flow
      // and the creditFeathers path both write via FieldValue.increment
      // through the same update call.
      allow update: if isOwner(userId)
        && fieldUnchanged('email')
        && fieldUnchanged('createdAt');

      // Account deletion is the deleteAccount callable cloud function's
      // job (it uses the Admin SDK and tears down related data). Block
      // direct client deletes so a stolen session can't nuke a profile
      // without going through the verified flow.
      allow delete: if false;
    }

    // * Default deny
    //
    // rules_version 2 already denies anything that doesn't match a rule,
    // but the explicit catch-all below keeps the intent obvious to anyone
    // reading the file later.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
